{
  "name": "ts-simple-ioc",
  "description": "Simple TypeScript based IoC framework",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "lint": "eslint && prettier . -c",
    "lint:fix": "eslint --fix && prettier . -w",
    "build": "tsc --build ./src/tsconfig.json",
    "test": "vitest"
  },
  "keywords": [
    "TypeScript",
    "ts",
    "IoC",
    "dependency",
    "injection",
    "DI"
  ],
  "author": "Carl Hartshorn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/carl-hartshorn/ts-simple-ioc.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "files": [
    "lib/"
  ],
  "type": "module"
}
